# ============================================================
# SkillPort — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRY_HOURS=24

# --- MongoDB ---
MONGO_USER=skillport
MONGO_PASSWORD=skillport_secret
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=skillport

# --- ClickHouse ---
CLICKHOUSE_USER=skillport
CLICKHOUSE_PASSWORD=skillport_secret
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=skillport_analytics

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# --- Milvus ---
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- Kafka ---
KAFKA_BROKERS=localhost:9092

# --- RabbitMQ ---
RABBITMQ_USER=skillport
RABBITMQ_PASSWORD=skillport_secret
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# --- Valkey (Redis-compatible) ---
VALKEY_HOST=localhost
VALKEY_PORT=6379

# --- MinIO (Milvus dependency) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080/api/v1
